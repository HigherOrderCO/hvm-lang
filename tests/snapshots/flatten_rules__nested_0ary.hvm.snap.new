(Cons) = λhead λtail #List λCons #List λNil #List.Cons.tail (#List.Cons.head (Cons head) tail)

(Nil) = #List λCons #List λNil Nil

(Unpack cmp (Nil)) = Nil
(Unpack cmp (Cons h (Nil))) = h
(Unpack cmp xs) = (cmp xs)
